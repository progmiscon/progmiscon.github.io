{"componentChunkName":"component---src-templates-reference-js","path":"/reference/sleemanPascalHighSchool1986/","result":{"data":{"zoteroItems":{"citationKey":"sleemanPascalHighSchool1986","data":{"key":"RK2S7WMD","version":32,"itemType":"journalArticle","title":"Pascal and High School Students: A Study of Errors","abstractNote":"A screening test was given to three classes of high school students, who were just completing introductory semester-long courses in Pascal. These tests were graded, and subsequently thirty-five students were given detailed clinical interviews. These interviews showed that errors were made with essentially every Pascal construct. Over half the students were classified as having major difficulties—fewer than 10 percent had no difficulties. The errors noted are discussed in detail in this article. A major finding is that the students attribute to the computer the reasoning power of an average person. The article also speculates about how difficult it might be to remediate the errors found, and concludes with an outline of future work.","date":"February 1, 1986","proceedingsTitle":null,"conferenceName":null,"place":null,"publisher":null,"volume":"2","pages":"5-23","series":"","language":"en","DOI":"10.2190/2XPP-LTYH-98NQ-BU77","ISBN":null,"shortTitle":"Pascal and High School Students","url":"https://doi.org/10.2190/2XPP-LTYH-98NQ-BU77","accessDate":"2021.01.08","archive":"","archiveLocation":"","libraryCatalog":"SAGE Journals","callNumber":"","rights":"","extra":"00000 \ntex.ids: sleemanPascalHighSchool1986, sleemanPascalHighSchool1986b\npublisher: SAGE Publications Inc\nCitation Key: sleemanPascalHighSchool1986","dateAdded":"2024-06-27T08:11:00Z","dateModified":"2024-06-27T08:11:43Z","reportNumber":null,"reportType":null,"seriesTitle":"","institution":null,"publicationTitle":"Journal of Educational Computing Research","issue":"1","seriesText":"","journalAbbreviation":"Journal of Educational Computing Research","ISSN":"0735-6331","bookTitle":nu