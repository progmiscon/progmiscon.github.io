{"componentChunkName":"component---src-templates-reference-js","path":"/reference/paulHuntingHighLow2013/","result":{"data":{"zoteroItems":{"citationKey":"paulHuntingHighLow2013","data":{"key":"M3H6ZZ64","version":13,"itemType":"conferencePaper","title":"Hunting high and low: instruments to detect misconceptions related to algorithms and data structures","abstractNote":"We present the result of assessing ﬁrst-year students’ misconceptions related to algorithms and data structures. Our study conﬁrms ﬁndings from previous small-scale studies but additionally broadens the scope of the topics and methods investigated. The evaluation of our experiments sheds light on dependencies between active and passive knowledge as well as on the instruments used; in particular, we conclude that there is no “one size ﬁts all” instrument but that instruments should be selected depending on the topic at hand.","date":"2013","proceedingsTitle":"Proceeding of the 44th ACM technical symposium on Computer science education - SIGCSE '13","conferenceName":"Proceeding of the 44th ACM technical symposium","place":"Denver, Colorado, USA","publisher":"ACM Press","volume":"","pages":"29","series":"","language":"en","DOI":"10.1145/2445196.2445212","ISBN":"978-1-4503-1868-6","shortTitle":"Hunting high and low","url":"http://dl.acm.org/citation.cfm?doid=2445196.2445212","accessDate":"2018.10.22","archive":"","archiveLocation":"","libraryCatalog":"Crossref","callNumber":"","rights":"","extra":"Citation Key: paulHuntingHighLow2013","dateAdded":"2020-07-19T17:33:57Z","dateModified":"2020-10-25T13:12:11Z","reportNumber":null,"reportType":null,"seriesTitle":null,"institution":null,"publicationTitle":null,"issue":null,"seriesText":null,"journalAbbreviation":null,"ISSN":null,"bookTitle":null,"seriesNumber":null,"numberOfVolumes":null,"edition":null,"creators":[{"creatorType":"author","firstName":"Wolfgang","lastName":"Paul"},{"creatorType":"author","firstName":"Jan","lastName":"Vahrenhold"}],"tags":[],"par