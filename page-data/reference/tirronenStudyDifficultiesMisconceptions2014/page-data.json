{"componentChunkName":"component---src-templates-reference-js","path":"/reference/tirronenStudyDifficultiesMisconceptions2014/","result":{"data":{"zoteroItems":{"citationKey":"tirronenStudyDifficultiesMisconceptions2014","data":{"key":"HY9JWK2T","version":13,"itemType":"conferencePaper","title":"Study on difficulties and misconceptions with modern type systems","abstractNote":"Functional programming is often presented as an advantageous programming paradigm by its advocates, but many students and teachers consider it to be hard to learn. One particular hurdle in learning functional programming is mastering the modern type systems employed in these languages. In this article, we identify student diﬃculties with means of multiple choice questions embedded into the on-line materials of an introductory functional programming course. The most prevalent misconceptions were confusing with parametric polymorphism with subtyping, the assigning too much meaning to variables names, and confounding general language patterns with special cases.","date":"2014","proceedingsTitle":"Proceedings of the 2014 conference on Innovation & technology in computer science education - ITiCSE '14","conferenceName":"the 2014 conference","place":"Uppsala, Sweden","publisher":"ACM Press","volume":"","pages":"303-308","series":"","language":"en","DOI":"10.1145/2591708.2591726","ISBN":"978-1-4503-2833-3","shortTitle":"","url":"http://dl.acm.org/citation.cfm?doid=2591708.2591726","accessDate":"2020.06.22","archive":"","archiveLocation":"","libraryCatalog":"DOI.org (Crossref)","callNumber":"","rights":"","extra":"Citation Key: tirronenStudyDifficultiesMisconceptions2014","dateAdded":"2020-07-19T17:33:57Z","dateModified":"2020-10-25T13:12:11Z","reportNumber":null,"reportType":null,"seriesTitle":null,"institution":null,"publicationTitle":null,"issue":null,"seriesText":null,"journalAbbreviation":null,"ISSN":null,"bookTitle":null,"seriesNumber":null,"numberOfVolumes":null,"edition":null,"creators":[{"cre